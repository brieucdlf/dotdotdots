// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "play_sound_when_agent_done": true,
    "always_allow_tool_actions": true
  },
  "context_servers": {
        "local-mcp": {
            "source": "custom",
            "enabled": true,
            "command": "npx",
            "args": [
        "mcp-remote",
        "http://localhost:8000/mcp",
        "--header",
        "x-bflow-api-key:d6bb8c97618ec1e7c301bc0bf3deea310a466500"
      ],
            "env": {}
        },
        "ai-staging-mcp": {
            "source": "custom",
            "enabled": true,
            "command": "npx",
            "args": [
                "mcp-remote",
                "https://api.ai-staging.bloomflow.com/mcp/",
                "--header",
                "x-bflow-api-key:1e41594b0a44e6d827ed9ff7801904e7b093f3d0"
            ],
            "env": {}
        }
    },
  "buffer_font_features": {
    "calt": 1
  },
  "vim_mode": true,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Gruvbox Dark"
  }
}
